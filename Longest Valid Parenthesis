#include <string>
#include <stack>
#include <algorithm>

class Solution {
public:
    int longestValidParentheses(std::string s) {
        std::stack<int> indices;
        indices.push(-1); // Base index for calculation
        int maxLength = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s[i] == '(') {
                indices.push(i);
            } else {
                indices.pop();
                if (indices.empty()) {
                    indices.push(i); // New base index
                } else {
                    maxLength = std::max(maxLength, i - indices.top());
                }
            }
        }
        return maxLength;
    }
};
