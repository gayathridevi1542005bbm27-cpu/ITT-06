#include <vector>
#include <string>

using namespace std;

class Solution {
public:
    vector<string> fullJustify(vector<string>& words, int maxWidth) {
        vector<string> result;
        int n = words.size();
        int i = 0;

        while (i < n) {
            int j = i + 1;
            int lineLength = words[i].size();

            // Pack as many words as possible into the current line
            while (j < n && lineLength + words[j].size() + (j - i) <= maxWidth) {
                lineLength += words[j].size();
                j++;
            }

            int numWords = j - i;
            int totalSpaces = maxWidth - lineLength;

            string line;

            // Handle last line or single word line
            if (j == n || numWords == 1) {
                line = words[i];
                for (int k = i + 1; k < j; k++) {
                    line += " " + words[k];
                }
                line += string(maxWidth - line.size(), ' ');
            } else {
                int spacePerGap = totalSpaces / (numWords - 1);
                int extraSpaces = totalSpaces % (numWords - 1);

                line = words[i];
                for (int k = i + 1; k < j; k++) {
                    line += string(spacePerGap + (extraSpaces-- > 0 ? 1 : 0), ' ');
                    line += words[k];
                }
            }

            result.push_back(line);
            i = j;
        }

        return result;
    }
};
